	--ax-surface-3: #F1F5F9;
	--ax-bg-card-hover: #FFFFFF;
	--ax-line: #E2E8F0;
	--ax-line-soft: rgba(226,232,240,0.5);
	--ax-line-strong: #CBD5E1;
	--ax-border-input: #E2E8F0;
	--ax-border-input-focus: #3b82f6;
	--ax-ink: #1e293b;
	--ax-muted: #475569;
	--ax-faint: #94a3b8;
	--ax-accent: #3b82f6;
	--ax-accent-light: #0ea5e9;
	--ax-accent-dim: rgba(59,130,246,0.06);
	--ax-shadow-card: 0 1px 3px rgba(0,0,0,0.05);
	--ax-shadow-card-hover: 0 4px 12px rgba(0,0,0,0.08);
	--ax-progress-from: #3b82f6;
	--ax-progress-to: #0ea5e9;
	--ax-accent-rgb: 59,130,246;
	--ax-green-rgb: 52,211,153;
	--ax-red-rgb: 248,113,113;
	--ax-yellow-rgb: 251,191,36;
	--ax-cyan-rgb: 34,211,238;
}

