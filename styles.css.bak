/*
 * Axlumen Dashboard — Apex-Grade Glassmorphism Design System
 * 6 themes × light/dark, aurora animation, translucent surfaces
 *
 * Inspired by apex-dashboard (PandoraReads)
 * Upgraded: glass cards, multi-theme, atmospheric backgrounds
 */

/* ===== Aurora Background Animation ===== */
@keyframes ax-aurora-shift {
	0%   { background-position: 0% 50%; }
	50%  { background-position: 100% 50%; }
	100% { background-position: 0% 50%; }
}

/* =================================================================
   THEME VARIABLES — 6 themes, each with light + dark
   ================================================================= */

/* ─── 1. AURORA (极光) ─── */
.axlumen-theme-aurora {
	--ax-bg: #0f0a1e;
	--ax-bg-section: rgba(139, 92, 246, 0.05);
	--ax-surface: rgba(255, 255, 255, 0.06);
	--ax-surface-2: rgba(255, 255, 255, 0.10);
	--ax-surface-3: rgba(255, 255, 255, 0.14);
	--ax-bg-card-hover: rgba(255, 255, 255, 0.12);
	--ax-line: rgba(255, 255, 255, 0.08);
	--ax-line-soft: rgba(255, 255, 255, 0.05);
	--ax-line-strong: rgba(255, 255, 255, 0.15);
	--ax-border-input: rgba(255, 255, 255, 0.08);
	--ax-border-input-focus: rgba(139, 92, 246, 0.6);
	--ax-ink: #e8f0f8;
	--ax-muted: #94a8c0;
	--ax-faint: #5a7088;
	--ax-accent: #a78bfa;
	--ax-accent-light: #6366f1;
	--ax-accent-dim: rgba(167, 139, 250, 0.12);
	--ax-green: #34d399;
	--ax-amber: #fbbf24;
	--ax-rose: #f43f5e;
	--ax-blue: #60a5fa;
	--ax-cyan: #22d3ee;
	--ax-violet: #a78bfa;
	--ax-pink: #f472b6;
	--ax-shadow-card: 0 2px 12px rgba(0,0,0,0.3);
	--ax-shadow-card-hover: 0 6px 24px rgba(139,92,246,0.15), 0 0 16px rgba(99,102,241,0.08);
	--ax-backdrop-blur: blur(12px);
	--ax-radius-sm: 8px;
	--ax-radius-md: 14px;
	--ax-radius-lg: 18px;
	--ax-font: 'DM Sans','Noto Sans SC',var(--font-interface-theme, system-ui);
	--ax-progress-from: #a78bfa;
	--ax-progress-to: #6366f1;
	--ax-aurora-bg: linear-gradient(135deg,#0f0a1e 0%,rgba(139,92,246,0.10) 20%,rgba(99,102,241,0.08) 40%,rgba(168,85,247,0.06) 60%,rgba(79,70,229,0.08) 80%,#0f0a1e 100%);
	--ax-aurora-size: 400% 400%;
	--ax-aurora-speed: 12s;
	--ax-accent-rgb: 167,139,250;
	--ax-green-rgb: 52,211,153;
	--ax-red-rgb: 244,63,94;
	--ax-yellow-rgb: 251,191,36;
	--ax-cyan-rgb: 34,211,238;
}
.theme-light .axlumen-theme-aurora {
	--ax-bg: #f3f0ff;
	--ax-surface: rgba(255,255,255,0.70);
	--ax-surface-2: rgba(255,255,255,0.85);
	--ax-surface-3: rgba(255,255,255,0.95);
	--ax-bg-card-hover: rgba(255,255,255,0.90);
	--ax-line: rgba(139,92,246,0.10);
	--ax-line-soft: rgba(139,92,246,0.06);
	--ax-line-strong: rgba(139,92,246,0.18);
	--ax-border-input: rgba(139,92,246,0.10);
	--ax-border-input-focus: rgba(139,92,246,0.5);
	--ax-ink: #1e293b;
	--ax-muted: #475569;
	--ax-faint: #94a3b8;
	--ax-accent: #7c3aed;
	--ax-accent-light: #6366f1;
	--ax-accent-dim: rgba(124,58,237,0.08);
	--ax-shadow-card: 0 2px 12px rgba(139,92,246,0.06);
	--ax-shadow-card-hover: 0 8px 32px rgba(139,92,246,0.10),0 4px 16px rgba(0,0,0,0.06);
	--ax-progress-from: #7c3aed;
	--ax-progress-to: #6366f1;
	--ax-aurora-bg: linear-gradient(135deg,#f3f0ff 0%,rgba(139,92,246,0.08) 20%,rgba(99,102,241,0.06) 40%,rgba(168,85,247,0.05) 60%,rgba(79,70,229,0.06) 80%,#f3f0ff 100%);
	--ax-accent-rgb: 124,58,237;
	--ax-green-rgb: 52,211,153;
	--ax-red-rgb: 244,63,94;
	--ax-yellow-rgb: 251,191,36;
	--ax-cyan-rgb: 34,211,238;
}

/* ─── 2. NORDIC ─── */
.axlumen-theme-nordic {
	--ax-bg: #0f172a;
	--ax-bg-section: #1e293b;
	--ax-surface: rgba(255,255,255,0.06);
	--ax-surface-2: rgba(255,255,255,0.10);
	--ax-surface-3: rgba(255,255,255,0.14);
	--ax-bg-card-hover: rgba(255,255,255,0.12);
	--ax-line: rgba(255,255,255,0.08);
	--ax-line-soft: rgba(255,255,255,0.04);
	--ax-line-strong: rgba(255,255,255,0.15);
	--ax-border-input: rgba(255,255,255,0.08);
	--ax-border-input-focus: rgba(59,130,246,0.6);
	--ax-ink: #e2e8f0;
	--ax-muted: #94a3b8;
	--ax-faint: #64748b;
	--ax-accent: #60a5fa;
	--ax-accent-light: #38bdf8;
	--ax-accent-dim: rgba(96,165,250,0.10);
	--ax-green: #34d399;
	--ax-amber: #fbbf24;
	--ax-rose: #f87171;
	--ax-blue: #60a5fa;
	--ax-cyan: #22d3ee;
